# AI Photo Restore Environment Variables

# Replicate API Token (get from https://replicate.com)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Optional: Cloudflare API for R2 storage
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# R2_BUCKET_NAME=ai-photo-restore

# If not configured, the app runs in demo mode (no actual AI processing)
